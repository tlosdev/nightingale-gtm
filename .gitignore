# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Editor
.vscode/
.idea/
*.swp
*~

# Obsidian (this repo is NOT an Obsidian vault — do not commit vault state)
.obsidian/

# Claude Code local user state (per-user settings, not repo state)
.claude/settings.local.json
.claude/cache/
.claude/plans/
.claude/state/

# Runtime artifacts (these belong on the user's Desktop, never in the repo)
nightingale-signals/

# Per-user secrets (live at $env:USERPROFILE\.nightingale\ by design; defense-in-depth)
.nightingale/

# Logs
*.log

# UI build artifacts + per-machine node deps (UI source is committed; outputs are not)
ui/node_modules/
ui/web/dist/
ui/.vite/

# Generated desktop-icon asset (install-desktop-icon.ps1 regenerates it on demand)
scripts/assets/
