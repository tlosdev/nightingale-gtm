.claude/settings.local.json
.claude/cache/
.claude/plans/
.claude/state/

# Runtime artifacts (these belong on the user's Desktop, never in the repo)
nightingale-signals/

# Per-user secrets (live at $env:USERPROFILE\.nightingale\ by design; defense-in-depth)
.nightingale/

# Logs
*.log
