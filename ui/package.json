{
  "name": "nightingale-ui",
  "version": "0.1.0",
  "private": true,
  "description": "Local Node.js + React control panel for the Nightingale GTM agent chain. Opt-in companion to the PowerShell + scheduled task primary flow. Loopback-only; reads ~/Desktop/nightingale-signals/**; invokes claude -p '<trigger>' for agent control and HubSpot approval actions.",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n server,web -c blue,green \"npm run dev:server\" \"npm run dev:web\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:web": "vite",
    "build": "vite build",
    "start": "tsx server/index.ts",
    "typecheck": "tsc --noEmit -p tsconfig.server.json && tsc --noEmit -p tsconfig.web.json"
  },
  "dependencies": {
    "express": "^4.21.1",
    "helmet": "^8.0.0",
    "marked": "^14.1.3",
    "isomorphic-dompurify": "^2.16.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.59.0",
    "@types/express": "^5.0.0",
    "@types/marked": "^6.0.0",
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.10",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "postcss": "^8.4.47",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.8"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
